# Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Relational Database
DATABASE_URL=postgresql://username:password@localhost:5432/ragnr_metadata

# Object Storage (MinIO)
AWS_ACCESS_KEY_ID=your_minio_user
AWS_SECRET_ACCESS_KEY=your_minio_password
S3_ENDPOINT_URL=http://localhost:9000

# LLM Providers
LLM_PROVIDER=groq
GROQ_API_KEYS=your_groq_api_key_1,your_groq_api_key_2
GOOGLE_API_KEY=your_google_api_key

# Azure OpenAI (Optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o-mini

# LangSmith Observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=ragnr-ai

# Integrations & App Config
GITHUB_TOKEN=your_github_token
PHOENIX_PROJECT_NAME=ragnr-ai
MAX_MEMORY_TOKENS=1000